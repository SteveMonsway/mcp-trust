{
  "name": "@mcp-trust/cli",
  "version": "0.5.4",
  "description": "Evidence-based preflight security scanner for Model Context Protocol (MCP) servers.",
  "type": "module",
  "bin": {
    "mcp-trust": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": ["dist", "README.md"],
  "engines": {
    "node": ">=20"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SteveMonsway/mcp-trust.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/SteveMonsway/mcp-trust#readme",
  "bugs": {
    "url": "https://github.com/SteveMonsway/mcp-trust/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-security",
    "agent-security",
    "llm-security",
    "security-scanner",
    "supply-chain-security",
    "semgrep",
    "sarif"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "execa": "9.6.1",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@mcp-trust/core": "workspace:*",
    "@mcp-trust/rules": "workspace:*",
    "@mcp-trust/resolvers": "workspace:*",
    "@mcp-trust/config-scanner": "workspace:*",
    "@mcp-trust/static-scanner": "workspace:*",
    "@mcp-trust/introspection": "workspace:*",
    "@mcp-trust/sandbox": "workspace:*",
    "@mcp-trust/report": "workspace:*",
    "@types/js-yaml": "^4.0.9",
    "tsx": "^4.19.2"
  }
}
